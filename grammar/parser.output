Terminals unused in grammar

    "%="


Grammar

    0 $accept: Program $end

    1 Program: $end
    2        | Statements $end

    3 Statements: Statement
    4           | Statements Statement

    5 Statement: ";"
    6          | Expr ";"
    7          | "(" Expr ")"
    8          | "return" Expr ";"
    9          | "return" ";"
   10          | If_Stm
   11          | While_Stm
   12          | For_Stm
   13          | Print ";"

   14 Scope: StartScope Statements EndScope
   15      | StartScope EndScope

   16 StartScope: "{"

   17 EndScope: "}"

   18 If_Stm: "if" "(" Expr ")" Scope
   19       | "if" "(" Expr ")" Scope "else" Scope

   20 For_Stm: "for" "(" Assign ";" Expr ";" Assign ")" Scope

   21 While_Stm: "while" "(" Expr ")" Scope

   22 Assign: Variable "=" Expr
   23       | Variable "+=" Expr
   24       | Variable "-=" Expr
   25       | Variable "*=" Expr
   26       | Variable "/=" Expr

   27 Print: "print" Expr

   28 Expr: Postfix
   29     | BinaryOp
   30     | UnaryOp
   31     | Assign

   32 BinaryOp: Expr "+" Expr
   33         | Expr "-" Expr
   34         | Expr "*" Expr
   35         | Expr "/" Expr
   36         | Expr ">" Expr
   37         | Expr "<" Expr
   38         | Expr ">=" Expr
   39         | Expr "<=" Expr
   40         | Expr "==" Expr
   41         | Expr "!=" Expr
   42         | Expr "&&" Expr
   43         | Expr "||" Expr
   44         | Expr "&" Expr
   45         | Expr "|" Expr
   46         | Expr "%" Expr

   47 UnaryOp: "-" Expr
   48        | "!" Expr

   49 Variable: "identifier"

   50 ArgListOpt: ε
   51           | ArgList

   52 ArgList: Expr
   53        | ArgList "," Expr

   54 ParamListOpt: ε
   55             | ParamList

   56 ParamList: "identifier"
   57          | ParamList "," "identifier"

   58 NameOpt: ε
   59        | ":" "identifier"

   60 FunctionLit: "func" "(" ParamListOpt ")" NameOpt Scope

   61 Primary: "number"
   62        | "?"
   63        | Variable
   64        | Scope
   65        | FunctionLit

   66 Postfix: Primary
   67        | Postfix "(" ArgListOpt ")"


